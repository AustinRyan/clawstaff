# ─── Required ──────────────────────────────────────────────
# Path to agent workspaces (local dev default)
AGENT_DATA_PATH=~/clawstaff/agents

# OpenClaw Gateway WebSocket URL
OPENCLAW_GATEWAY_URL=ws://127.0.0.1:18789

# App URL (used for internal links)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Moltbook (optional) ──────────────────────────────────
# Agent reputation platform — agents build public, verifiable profiles
# Get your token at https://www.moltbook.com
MOLTBOOK_API_KEY=moltbook_sk_...

# ─── Scout — Prospect Discovery (optional) ─────────────────
# Google Places API key for business discovery
# Get one at https://console.cloud.google.com (free $200/mo credit)
GOOGLE_PLACES_API_KEY=AIza...

# Tavily API key for web research on prospects
# Get one at https://tavily.com
TAVILY_API_KEY=tvly-...

# ─── Demo Mode (optional) ──────────────────────────────────
# Set to "true" for cinematic dashboard enhancements (screenshots/video)
# Adds animations, count-ups, live feed, cursor trail, gradient mesh
NEXT_PUBLIC_DEMO_MODE=false

# ─── Production (VPS deployment) ───────────────────────────
# Uncomment these when deploying to a VPS:
# AGENT_DATA_PATH=/opt/clawstaff/agents
# ENVIRONMENT=production
